<q-dialog v-model="dialog">
  <q-card style="min-width: 400px;">
    
    <q-card-section>
      <div class="text-h6">Ajouter utilisateur</div>
    </q-card-section>

    <q-card-section class="q-gutter-md">

      <q-input v-model="form.name" label="Nom" />

      <q-input v-model="form.email" label="Email" />

      <q-input v-model="form.password" label="Password" type="password" />

      <q-input v-model="form.password_confirmation" label="Confirmer" type="password" />

      <q-select
        v-model="form.role"
        :options="adminStore.roles.map(r => r.name)"
        label="Rôle"
      />

    </q-card-section>

    <q-card-actions align="right">
      <q-btn flat label="Annuler" v-close-popup />
      <q-btn color="primary" label="Créer" @click="submit" />
    </q-card-actions>

  </q-card>
</q-dialog>
