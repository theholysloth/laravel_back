import { mount } from '@vue/test-utils' //mount permet de monter le composant complet dans l'env test
import { describe, it, expect, vi } from 'vitest'
import TaskForm from './TaskForm.vue'//etant donné qu'on teste TaskForm , on l'import
//import { useQuasar } from 'quasar'
import { nextTick } from 'vue' //nextTick permet d'attendre la maj du dom apres une action

describe('TaskForm', () => {
    //
  it('affichage en mode add', () => {
    const wrapper = mount(TaskForm, {
      props: { mode: 'add' }//on cree des props qui sont utile pour le composant 
    })

    expect(wrapper.find('input')).toBeTruthy()//wrapper permet d'interragir avec TaskForm car le composant y est stocké
    expect(wrapper.find('button').text()).toContain('Ajouter')//le button en mode add
  })




  it('add-task en mode add', async () => {
    const wrapper = mount(TaskForm, {
      props: { mode: 'add' },
      global: {
    mocks: {
      $q: {
        notify: vi.fn(),
        platform: {
          has: {
            touch: false
          }
        }
      }
    }
  }
    })
    

    const inputs = wrapper.findAll('.q-field__native')//on recupere les champs du formulaire
    console.log("Inputs trouvés :", inputs.length)

    if (inputs.length === 0) {
      console.log("Aucun input trouvé:STOP")
      return
    }

    await inputs[0].setValue('junior')
    await inputs[1].setValue('Faire le rapport')
    await inputs[2].setValue('2025-01-01')
    console.log("Valeurs après setValue :")
    console.log("nom =", inputs[0].element.value)
    console.log("task =", inputs[1].element.value)
    console.log("date =", inputs[2].element.value)

    await wrapper.find('form').trigger('submit.prevent')//on envoie 
    await nextTick()
    console.log("Events émis :", wrapper.emitted())

    const emitted = wrapper.emitted('add-task')//on recupere tout les evenements nommés add-task envoyés par TaskForm
    console.log("add-task =", emitted)
    expect(emitted).toBeTruthy()//verif que l'event a eu lieu
    

    expect(emitted[0][0]).toEqual({//pareil que expect(payload).toEqual({})
      nom: 'junior',
      task: 'Faire le rapport',
      date: '2025-01-01',
      done: false
    })
  })



  it('réinitialise après add réussi', async () => {
    const wrapper = mount(TaskForm, {
      props: { mode: 'add' },
      global: {
    mocks: {
      $q: {
        notify: vi.fn(),
        platform: {
          has: {
            touch: false
          }
        }
      }
    }
  }
    })

    const inputs = wrapper.findAll('.q-field__native')
    await inputs[0].setValue('junior')
    await inputs[1].setValue('Coder')
    await inputs[2].setValue('2025-02-02')

    await wrapper.find('form').trigger('submit.prevent')
    await nextTick()

    const updatedInputs = wrapper.findAll('input')
    expect(updatedInputs[0].element.value).toBe('')
    expect(updatedInputs[1].element.value).toBe('')
    expect(updatedInputs[2].element.value).toBe('')
  })

  it('update-task en mode edit', async () => {
    const wrapper = mount(TaskForm, {
      props: {
        mode: 'edit',//TaskForm en mode edit
        initialNom: 'Charlie',
        initialTask: 'Relire',
        initialDate: '2025-03-03',
        initialDone: true,
        id: 42
      },
      global: {
    mocks: {
      $q: {
        notify: vi.fn(),
        platform: {
          has: {
            touch: false
          }
        }
      }
    }
  }
    })

    const inputs = wrapper.findAll('input')
    //console.log(inputs[0])
    await inputs[0].setValue('Charlie Modifié')
    await inputs[1].setValue('Relire encore')
    await inputs[2].setValue('2025-03-10')

    await wrapper.find('form').trigger('submit.prevent')
    await nextTick()

    const emitted = wrapper.emitted('update-task')
    expect(emitted).toBeTruthy()

    expect(emitted[0][0]).toEqual({
      nom: 'Charlie Modifié',
      task: 'Relire encore',
      date: '2025-03-10',
      done: true,
      id: 42
    })
  })

  it('$q.notify si succès', async () => {
    const wrapper = mount(TaskForm, { props: { mode: 'add' },
    global: {
    mocks: {
      $q: {
        notify: vi.fn(),
        platform: {
          has: {
            touch: false
          }
        }
      }
    }
  }
 })

    const notifySpy = vi.spyOn(wrapper.vm.$q, 'notify')

    const inputs = wrapper.findAll('.q-field__native')

    await inputs[0].setValue('David')
    await inputs[1].setValue('Tester')
    await inputs[2].setValue('2025-04-04')

    await wrapper.find('form').trigger('submit.prevent')
    await nextTick()

    expect(notifySpy).toHaveBeenCalled()
  })
})


