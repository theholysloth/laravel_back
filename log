# Cache Composer
cache:
  paths:
    - vendor/
    - .composer/


install_back:
  stage: install
  image: php:8.3
  services:
    - name: mysql:8.4
      alias: db
  script:
    - apt-get update && apt-get install -y unzip git libzip-dev libpng-dev libonig-dev libxml2-dev #installation des biblio necessaire à laravel,composer,..
    - docker-php-ext-install pdo_mysql zip #extensions pour se connecter à mysql, pour composer 
    - curl -sS https://getcomposer.org/installer | php #installation de composer 
    - php composer.phar install --no-interaction --prefer-dist # <=> composer install
  artifacts:
    paths:
      - vendor/
    expire_in: 1 week


test_back:
  stage: test
  image: php:8.3
  services:
    - name: mysql:8.4
      alias: db
  script:
    - apt-get update && apt-get install -y unzip git libzip-dev libpng-dev libonig-dev libxml2-dev
    - docker-php-ext-install pdo_mysql zip
    - curl -sS https://getcomposer.org/installer | php
    - php composer.phar install --no-interaction --prefer-dist
    #- until mysql -h db -u laravel -psecret -e "SELECT 1"; do sleep 2; done
    - php artisan migrate --force #migration pour les features qui utilisent la BD 
    - ./vendor/bin/pest
    - ./vendor/bin/phpunit
  needs:
    - install_back


build_back:
  stage: build
  image: php:8.3
  script:
    - apt-get update && apt-get install -y unzip git libzip-dev libpng-dev libonig-dev libxml2-dev
    - docker-php-ext-install pdo_mysql zip
    - curl -sS https://getcomposer.org/installer | php
    - php composer.phar install --no-interaction --prefer-dist --no-dev
    - php artisan config:cache #accelere le chargement de l'app
    - php artisan route:cache #toute les routes dans un fichier 
    - php artisan event:cache
    - php artisan optimize
  artifacts:
    paths:
      - vendor/
      - bootstrap/cache/
    expire_in: 1 week
  needs:
    - install_back
