<q-dialog v-model="editDialog">
  <q-card style="min-width: 400px;">
    
    <q-card-section>
      <div class="text-h6">Modifier utilisateur</div>
    </q-card-section>

    <q-card-section class="q-gutter-md">

      <q-input v-model="editedUser.name" label="Nom" />
      <q-input v-model="editedUser.email" label="Email" />

      <q-select
        v-model="editedUser.role"
        :options="adminStore.roles.map(r => r.name)"
        label="Rôle"
      />

    </q-card-section>

    <q-card-actions align="right">
      <q-btn flat label="Annuler" v-close-popup />
      <q-btn color="primary" label="Mettre à jour" @click="updateUser" />
    </q-card-actions>

  </q-card>
</q-dialog>
